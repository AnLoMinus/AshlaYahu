{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Holly Hype platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "lastSeen": { "type": "string", "format": "date-time" },
        "isOnline": { "type": "boolean" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A private AI chat session for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat or room.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant", "system"] },
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "createdAt"]
    },
    "Room": {
      "title": "Room",
      "description": "A collaborative meeting room.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "participants": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "createdBy", "createdAt", "participants"]
    },
    "Substitute": {
      "title": "Substitute",
      "description": "A community-generated holy substitute for an experience.",
      "type": "object",
      "properties": {
        "experienceId": { "type": "string" },
        "type": { "type": "string", "enum": ["plants", "breathing", "meditation", "music", "movement", "other"] },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "upvotes": { "type": "number" }
      },
      "required": ["experienceId", "type", "name", "description", "createdBy", "creatorName", "createdAt", "upvotes"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Private chats."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages in a private chat."
    },
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Collaborative rooms."
    },
    "/rooms/{roomId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages in a collaborative room."
    },
    "/substitutes/{substituteId}": {
      "schema": { "$ref": "#/entities/Substitute" },
      "description": "Community generated substitutes."
    }
  }
}
